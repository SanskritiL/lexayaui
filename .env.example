# App URLs
APP_BASE_URL=http://localhost:3000
SUPPORT_EMAIL=support@example.com
LEXAYA_API_BASE_URL=http://localhost:8080
LEXAYA_PUBLISH_BASE_URL=http://localhost:8081

# Public browser config. Copy these into js/config.js for static hosting.
LEXAYA_SUPABASE_URL=https://your-project.supabase.co
LEXAYA_SUPABASE_ANON_KEY=your-supabase-anon-key
LEXAYA_STRIPE_PUBLISHABLE_KEY=pk_test_or_live_xxx
LEXAYA_BROADCAST_PRO_PRICE_ID=price_xxx

# Cloud Run web API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Firebase project used for auth (usually the same GCP project as Cloud Run).
# Local verification of Firebase ID tokens also needs Application Default
# Credentials: run `gcloud auth application-default login` once.
FIREBASE_PROJECT_ID=your-firebase-project-id
STRIPE_SECRET_KEY=sk_test_or_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
GOOGLE_API_KEY=your-gemini-api-key
CRON_SECRET=a-long-random-secret
# Publishing is admin-only; everyone else gets Instagram DM automation.
# Comma-separated. If empty, every publish request is rejected.
ADMIN_EMAILS=you@example.com

# Social OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-random-webhook-verify-token
INSTAGRAM_REDIRECT_URI=http://localhost:8080/api/broadcast/auth/instagram
INSTAGRAM_PUBLISHING_ENABLED=false
META_GRAPH_VERSION=v25.0
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_EXTRA_SCOPES=
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Cloud Run publish service
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
REGION=us-central1
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=lexaya-videos
R2_PUBLIC_URL=https://your-public-r2-domain.example.com
