{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/broadcast/auth/:platform", "destination": "/api/broadcast/auth/[platform]" },
    { "source": "/kit/:token", "destination": "/kit/index.html" },

    { "source": "/api/broadcast/publish", "destination": "https://publish-service-266355090145.us-central1.run.app/broadcast/publish" },
    { "source": "/api/broadcast/upload", "destination": "https://publish-service-266355090145.us-central1.run.app/uploads/r2-url" },
    { "source": "/api/publish/with-file", "destination": "https://publish-service-266355090145.us-central1.run.app/publish/with-file" },
    { "source": "/api/publish/:path*", "destination": "https://publish-service-266355090145.us-central1.run.app/:path*" }
  ],
  "functions": {
    "api/broadcast/init-video.js": {
      "maxDuration": 60
    }
  }
}
